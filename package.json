{
  "name": "@open-aviation-solutions/components",
  "version": "0.1.1",
  "description": "Interactive aviation training components",
  "main": "./dist/lib/open-aviation-components.umd.js",
  "module": "./dist/lib/open-aviation-components.es.js",
  "exports": {
    ".": {
      "import": "./dist/lib/open-aviation-components.es.js",
      "require": "./dist/lib/open-aviation-components.umd.js"
    },
    "./define": "./dist/lib/define.es.js"
  },
  "types": "./dist/lib/index.d.ts",
  "files": [
    "dist/lib",
    "README.md",
    "LICENSE"
  ],
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Open-Aviation-Solutions/open-aviation-components.git"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:lib": "vite build --config vite.lib.config.js && vite build --config vite.define.config.js",
    "typecheck": "tsc --noEmit",
    "preview": "astro preview"
  },
  "peerDependencies": {
    "three": ">=0.184.0"
  },
  "devDependencies": {
    "@astrojs/starlight": "^0.38.4",
    "@types/three": "^0.184.0",
    "astro": "^6.2.1",
    "sharp": "^0.34.5",
    "three": "^0.184.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.5.4"
  }
}
