---
---
<div>
  <label style="display: flex; align-items: center; gap: 8px; margin-bottom: 12px; cursor: pointer;">
    <input type="checkbox" id="banking-toggle" checked />
    <span>banking</span>
  </label>
  <four-forces
    id="four-forces-demo"
    height="500px"
    model-path="/open-aviation-components/aircraft.glb"
    model-rotation="0,90,0"
    model-offset="0,-0.1,0"
    v_ne="45"
    v_no="35"
    v_1="22"
    cruise-kts="30"
    banking
  ></four-forces>
</div>

<script>
  import '../../src/define'

  const toggle = document.getElementById('banking-toggle') as HTMLInputElement
  const element = document.getElementById('four-forces-demo')!
  toggle.addEventListener('change', () => {
    if (toggle.checked) element.setAttribute('banking', '')
    else element.removeAttribute('banking')
  })
</script>
